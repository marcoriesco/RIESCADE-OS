{
  "$schema": "riescade-emulator-schema-v1",
  "id": "solarus2",
  "name": "Solarus 2 Engine",
  "description": "Ajuste os parâmetros da engine Solarus 2.",
  "icon": "solarus2",
  "configFiles": [],
  "globalMappings": {
    "forcefullscreen": {
      "configKey": "forcefullscreen",
      "globalKey": "fullscreen"
    }
  },
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "videomode",
          "label": "Modo de Vídeo",
          "description": "Resolução de tela para o emulador.",
          "type": "select",
          "default": "auto",
          "configKey": "videomode",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            }
          ]
        },
        {
          "id": "forcefullscreen",
          "label": "Desativar Tela Cheia",
          "description": "Se ativado, força a execução em modo janela.",
          "type": "toggle",
          "default": "auto",
          "configKey": "forcefullscreen",
          "inheritsGlobal": "fullscreen"
        }
      ]
    }
  ]
}