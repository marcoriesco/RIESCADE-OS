{
  "$schema": "riescade-emulator-schema-v1",
  "id": "vita3k",
  "name": "Vita3K",
  "description": "Emulador de PlayStation Vita.",
  "icon": "vita3k",
  "configFiles": [
    {
      "path": "config.yml",
      "format": "yml"
    }
  ],
  "globalMappings": {
    "fullscreen": {
      "configKey": "fullscreen",
      "globalKey": "fullscreen"
    },
    "vsync": {
      "configKey": "vsync",
      "globalKey": "vsync"
    },
    "video_driver": {
      "configKey": "video_driver",
      "globalKey": "video_driver"
    }
  },
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "fullscreen",
          "label": "Tela Cheia",
          "description": "Iniciar o emulador em modo tela cheia.",
          "type": "toggle",
          "default": "true",
          "configKey": "fullscreen",
          "inheritsGlobal": "fullscreen"
        },
        {
          "id": "video_driver",
          "label": "Backend Gráfico",
          "description": "API de renderização.",
          "type": "select",
          "default": "Vulkan",
          "configKey": "video_driver",
          "inheritsGlobal": "video_driver",
          "values": [
            {
              "label": "Vulkan",
              "value": "Vulkan"
            },
            {
              "label": "OpenGL",
              "value": "OpenGL"
            }
          ]
        },
        {
          "id": "vsync",
          "label": "V-Sync",
          "description": "Sincronização vertical.",
          "type": "toggle",
          "default": "true",
          "configKey": "vsync",
          "inheritsGlobal": "vsync"
        },
        {
          "id": "resolution",
          "label": "Resolução Interna",
          "description": "Multiplicador da resolução do PS Vita (960x544).",
          "type": "select",
          "default": "1",
          "configKey": "resolution",
          "values": [
            {
              "label": "1x Nativa",
              "value": "1"
            },
            {
              "label": "2x",
              "value": "2"
            },
            {
              "label": "3x",
              "value": "3"
            },
            {
              "label": "4x",
              "value": "4"
            }
          ]
        }
      ]
    }
  ]
}