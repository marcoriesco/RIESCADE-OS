            },
            {
              "label": "x16 (7680p - 16K)",
              "value": "16"
            }
          ]
        },
        {
          "id": "play_presentation",
          "label": "Proporção de Tela",
          "type": "select",
          "default": "auto",
          "configKey": "play_presentation",
          "values": [
            {
              "label": "FIT SCREEN",
              "value": "1"
