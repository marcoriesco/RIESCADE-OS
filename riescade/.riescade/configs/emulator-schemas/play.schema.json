          "type": "select",
          "default": "auto",
          "configKey": "play_resolution",
          "values": [
            {
              "label": "NATIVE (480p)",
              "value": "1"
            },
            {
              "label": "x2 (960p)",
              "value": "2"
            },
            {
              "label": "x4 (1920p)",
              "value": "4"
