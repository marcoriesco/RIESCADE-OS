{
  "$schema": "riescade-emulator-schema-v1",
  "id": "xash3d",
  "name": "Xash3D FWGS (Half-Life Engine)",
  "description": "Ajuste os parâmetros da engine Xash3D.",
  "icon": "xash3d",
  "configFiles": [],
  "globalMappings": {},
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "xash3d_vsync",
          "label": "Sincronização Vertical (V-Sync)",
          "type": "toggle",
          "default": "auto",
          "configKey": "xash3d_vsync"
        }
      ]
    },
    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "xash3d_showfps",
          "label": "SHOW FPS",
          "type": "toggle",
          "default": "auto",
          "configKey": "xash3d_showfps"
        }
      ]
    },
    {
      "id": "audio",
      "title": "Áudio",
      "icon": "volume2",
      "order": 4,
      "options": [
        {
          "id": "xash3d_disabledsp",
          "label": "DISABLE DSP",
          "type": "toggle",
          "default": "auto",
          "configKey": "xash3d_disabledsp"
        }
      ]
    },
    {
      "id": "controls",
      "title": "Controles",
      "icon": "gamepad2",
      "order": 5,
      "options": [
        {
          "id": "xash3d_invmouse",
          "label": "INVERT MOUSE",
          "type": "toggle",
          "default": "auto",
          "configKey": "xash3d_invmouse"
        },
        {
          "id": "xash3d_crosshair",
          "label": "SHOW CROSSHAIR",
          "type": "toggle",
          "default": "auto",
          "configKey": "xash3d_crosshair"
        },
        {
          "id": "xash3d_autoaim",
          "label": "Automático AIM",
          "type": "toggle",
          "default": "auto",
          "configKey": "xash3d_autoaim"
        },
        {
          "id": "xash3d_sensitivity",
          "label": "MOUSE SENSITIVITY",
          "type": "slider",
          "default": "auto",
          "configKey": "xash3d_sensitivity",
          "min": 0,
          "max": 20,
          "step": 0.5
        }
      ]
    }
  ]
}