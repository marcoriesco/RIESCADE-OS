{
  "$schema": "riescade-emulator-schema-v1",
  "id": "flycast",
  "name": "Flycast",
  "description": "Emulador de Sega Dreamcast / Naomi / Atomiswave.",
  "icon": "flycast",
  "configFiles": [
    {
      "path": "emu.cfg",
      "format": "cfg"
    }
  ],
  "globalMappings": {
    "fullscreen": {
      "configKey": "fullscreen",
      "globalKey": "fullscreen"
    },
    "vsync": {
      "configKey": "vsync",
      "globalKey": "vsync"
    }
  },
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "fullscreen",
          "label": "Tela Cheia",
          "description": "Iniciar o emulador em modo tela cheia.",
          "type": "toggle",
          "default": "true",
          "configKey": "fullscreen",
          "inheritsGlobal": "fullscreen"
        },
        {
          "id": "vsync",
          "label": "V-Sync",
          "description": "Sincronização vertical.",
          "type": "toggle",
          "default": "true",
          "configKey": "vsync",
          "inheritsGlobal": "vsync"
        },
        {
          "id": "flycast_internal_resolution",
          "label": "Resolução Interna",
          "description": "Multiplicador da resolução nativa.",
          "type": "select",
          "default": "auto",
          "configKey": "flycast_internal_resolution",
          "values": [
            {
              "label": "Automático",
              "value": "auto"
            },
            {
              "label": "1x Nativa",
              "value": "1"
            },
            {
              "label": "2x",
              "value": "2"
            },
            {
              "label": "3x",
              "value": "3"
            },
            {
              "label": "4x",
              "value": "4"
            }
          ]
        },
        {
          "id": "flycast_widescreen",
          "label": "Widescreen",
          "description": "Força proporção 16:9.",
          "type": "toggle",
          "default": "false",
          "configKey": "flycast_widescreen"
        },
        {
          "id": "flycast_anisotropic",
          "label": "Filtragem Anisotrópica",
          "description": "Melhora a nitidez de texturas.",
          "type": "select",
          "default": "1",
          "configKey": "flycast_anisotropic",
          "values": [
            {
              "label": "Desativado",
              "value": "1"
            },
            {
              "label": "2x",
              "value": "2"
            },
            {
              "label": "4x",
              "value": "4"
            },
            {
              "label": "8x",
              "value": "8"
            },
            {
              "label": "16x",
              "value": "16"
            }
          ]
        }
      ]
    }
  ]
}