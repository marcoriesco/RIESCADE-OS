{
  "$schema": "riescade-emulator-schema-v1",
  "id": "ares",
  "name": "Ares (Multi-sistema)",
  "description": "Ajuste os parâmetros específicos do emulador Ares.",
  "icon": "ares",
  "configFiles": [],
  "globalMappings": {},
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "ares_aspect",
          "label": "ASPECT RATIO",
          "type": "select",
          "default": "auto",
          "configKey": "ares_aspect",
          "values": [
            {
              "label": "SCALE (BEST FIT)",
              "value": "Scale"
            },
            {
              "label": "SCALE (INTEGER)",
              "value": "Integer"
            },
            {
              "label": "Esticar",
              "value": "Stretch"
            }
          ],
          "realKey": "Output",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_gpusync",
          "label": "Vídeo SYNC",
          "type": "select",
          "default": "auto",
          "configKey": "ares_gpusync",
          "values": [
            {
              "label": "SYNC",
              "value": "sync"
            },
            {
              "label": "GPU SYNC ONLY",
              "value": "gpu"
            },
            {
              "label": "SYNC + GPU",
              "value": "gpusync"
            },
            {
              "label": "Não",
              "value": "none"
            }
          ],
          "realKey": "Blocking",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_luminance",
          "label": "ADJUST LUMINANCE",
          "type": "slider",
          "default": "auto",
          "configKey": "ares_luminance",
          "min": 0,
          "max": 1,
          "step": 0.04,
          "suffix": "%",
          "realKey": "Luminance",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_saturation",
          "label": "ADJUST SATURATION",
          "type": "slider",
          "default": "auto",
          "configKey": "ares_saturation",
          "min": 0,
          "max": 2,
          "step": 0.04,
          "suffix": "%",
          "realKey": "Saturation",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_gamma",
          "label": "ADJUST GAMMA",
          "type": "slider",
          "default": "auto",
          "configKey": "ares_gamma",
          "min": 1,
          "max": 2,
          "step": 0.04,
          "suffix": "%",
          "realKey": "Gamma",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_colobleed",
          "label": "COLOR BLEED",
          "description": "Blurs adjacent pixels for translucency effects.",
          "type": "toggle",
          "default": "auto",
          "configKey": "ares_colobleed",
          "realKey": "ColorBleed",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_coloremulation",
          "label": "ACCURATE COLOR Emulação",
          "description": "Matches colors to how they look Ativado real hardware.",
          "type": "toggle",
          "default": "auto",
          "configKey": "ares_coloremulation",
          "realKey": "ColorEmulation",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_interframe_blend",
          "label": "INTERFRAME BLENDING",
          "description": "Emulates LCD translucency effects, but increase motion blur.",
          "type": "toggle",
          "default": "auto",
          "configKey": "ares_interframe_blend",
          "realKey": "InterframeBlending",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_overscan",
          "label": "OVERSCAN",
          "description": "Shows extended PAL CRT lines, but these are usually blank in most games.",
          "type": "toggle",
          "default": "auto",
          "configKey": "ares_overscan",
          "realKey": "Overscan",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_pixel_accurate",
          "label": "PIXEL ACCURACY",
          "description": "Use pixel-accurate Emulação where available.",
          "type": "toggle",
          "default": "auto",
          "configKey": "ares_pixel_accurate",
          "realKey": "PixelAccuracy",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_renderer",
          "label": "Vídeo",
          "type": "select",
          "default": "auto",
          "configKey": "ares_renderer",
          "values": [
            {
              "label": "OPENGL",
              "value": "OpenGL 3.2"
            },
            {
              "label": "DIRECT3D 9",
              "value": "Direct3D 9.0"
            },
            {
              "label": "GDI",
              "value": "GDI"
            }
          ],
          "realKey": "Driver",
          "realFile": "Ares.Generator.cs"
        }
      ]
    },
    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "ares_region",
          "label": "PREFERRED REGION",
          "type": "select",
          "default": "auto",
          "configKey": "ares_region",
          "values": [
            {
              "label": "PAL",
              "value": "PAL"
            },
            {
              "label": "NTSC(US)",
              "value": "NTSC-U"
            },
            {
              "label": "NTSC(JAPAN)",
              "value": "NTSC-J"
            }
          ],
          "realKey": "Prefer",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_fastboot",
          "label": "Inicialização Rápida (Fast Boot)",
          "type": "toggle",
          "default": "auto",
          "configKey": "ares_fastboot",
          "realKey": "Fast",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_runahead",
          "label": "ENABLE RUN-AHEAD",
          "description": "Removes one frame of input lag, but doubles system requirements.",
          "type": "toggle",
          "default": "auto",
          "configKey": "ares_runahead",
          "realKey": "RunAhead",
          "realFile": "Ares.Generator.cs"
        }
      ]
    },
    {
      "id": "hacks",
      "title": "Correções / Hacks",
      "icon": "wrench",
      "order": 3,
      "options": [
        {
          "id": "ares_aspectcorrection",
          "label": "ASPECT CORRECTION MODE",
          "type": "select",
          "default": "auto",
          "configKey": "ares_aspectcorrection",
          "values": [
            {
              "label": "STANDARD",
              "value": "Standard"
            },
            {
              "label": "Nenhum",
              "value": "None"
            },
            {
              "label": "ANAMORPHIC (16:9)",
              "value": "Anamorphic"
            }
          ],
          "realKey": "AspectCorrectionMode",
          "realFile": "Ares.Generator.cs"
        }
      ]
    },
    {
      "id": "audio",
      "title": "Áudio",
      "icon": "volume2",
      "order": 4,
      "options": [
        {
          "id": "ares_audio_renderer",
          "label": "Áudio",
          "type": "select",
          "default": "auto",
          "configKey": "ares_audio_renderer",
          "values": [
            {
              "label": "WASAPI",
              "value": "WASAPI"
            },
            {
              "label": "XAUDIO2",
              "value": "XAudio 2.1"
            },
            {
              "label": "SDL",
              "value": "SDL"
            },
            {
              "label": "DIRECTSOUND",
              "value": "DirectSound 7.0"
            },
            {
              "label": "WAVEOUT",
              "value": "waveOut"
            }
          ],
          "realKey": "Driver",
          "realFile": "Ares.Generator.cs"
        },
        {
          "id": "ares_audiosync",
          "label": "Áudio SYNC",
          "type": "toggle",
          "default": "auto",
          "configKey": "ares_audiosync",
          "realKey": "Blocking",
          "realFile": "Ares.Generator.cs"
        }
      ]
    }
  ]
}