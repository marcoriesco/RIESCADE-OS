{
  "$schema": "riescade-emulator-schema-v1",
  "id": "citron",
  "name": "Citron",
  "description": "Emulador de Nintendo Switch (fork).",
  "icon": "citron",
  "globalMappings": {
    "fullscreen": {
      "configKey": "fullscreen",
      "globalKey": "fullscreen"
    },
    "vsync": {
      "configKey": "vsync",
      "globalKey": "vsync"
    }
  },
  "configFiles": [
    {
      "path": "user/config/qt-config.ini",
      "format": "ini"
    }
  ],
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "fullscreen",
          "label": "Tela Cheia",
          "description": "Iniciar o emulador em modo tela cheia.",
          "type": "toggle",
          "default": "true",
          "configKey": "fullscreen",
          "inheritsGlobal": "fullscreen"
        },
        {
          "id": "vsync",
          "label": "V-Sync",
          "description": "Modo de sincronização vertical.",
          "type": "select",
          "default": "1",
          "configKey": "vsync",
          "inheritsGlobal": "vsync",
          "values": [
            {
              "label": "Desativado",
              "value": "0"
            },
            {
              "label": "FIFO (On)",
              "value": "1"
            },
            {
              "label": "Mailbox",
              "value": "2"
            }
          ]
        }
      ]
    },
    {
      "id": "system",
      "title": "Sistema",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "citron_undock",
          "label": "Modo Portátil (Undocked)",
          "description": "Emula o Switch no modo portátil.",
          "type": "toggle",
          "default": "false",
          "configKey": "citron_undock"
        }
      ]
    }
  ]
}