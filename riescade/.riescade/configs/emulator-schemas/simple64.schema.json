{
  "$schema": "riescade-emulator-schema-v1",
  "id": "simple64",
  "name": "simple64 (Nintendo 64)",
  "description": "Ajuste os parâmetros específicos do emulador simple64.",
  "icon": "simple64",
  "configFiles": [],
  "globalMappings": {},
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "parallel_upscaling",
          "label": "Resolução Interna",
          "type": "select",
          "default": "auto",
          "configKey": "parallel_upscaling",
          "values": [
            {
              "label": "1x",
              "value": "1"
            },
            {
              "label": "2x",
              "value": "2"
            },
            {
              "label": "4x",
              "value": "4"
            }
          ],
          "realKey": "Upscaling",
          "realSection": "Video-Parallel",
          "realFile": "Simple64.Generator.cs"
        },
        {
          "id": "vsync",
          "label": "Sincronização Vertical (V-Sync)",
          "type": "toggle",
          "default": "auto",
          "configKey": "vsync"
        },
        {
          "id": "n64_widescreen",
          "label": "Esticar TO SCREEN",
          "type": "toggle",
          "default": "auto",
          "configKey": "n64_widescreen",
          "realKey": "WidescreenStretch",
          "realSection": "Video-Parallel",
          "realFile": "Simple64.Generator.cs"
        },
        {
          "id": "antialiasing",
          "label": "Anti-Aliasing (FXAA)",
          "description": "Set Anti Aliasing for rendered content.",
          "type": "toggle",
          "default": "auto",
          "configKey": "antialiasing",
          "realKey": "VIAA",
          "realSection": "Video-Parallel",
          "realFile": "Simple64.Generator.cs"
        }
      ]
    },
    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "n64_mempack",
          "label": "DISABLE 4MB RAM PACK",
          "description": "Disabling the 4MB expansion RAM pack may be necessary for some games.",
          "type": "toggle",
          "default": "auto",
          "configKey": "n64_mempack",
          "realKey": "DisableExtraMem",
          "realSection": "Core",
          "realFile": "Simple64.Generator.cs"
        },
        {
          "id": "show_gui",
          "label": "SHOW EMULATOR GUI",
          "type": "toggle",
          "default": "auto",
          "configKey": "show_gui"
        }
      ]
    },
    {
      "id": "controls",
      "title": "Controles",
      "icon": "gamepad2",
      "order": 5,
      "options": [
        {
          "id": "simple64_inputplugin",
          "label": "INPUT",
          "type": "select",
          "default": "auto",
          "configKey": "simple64_inputplugin",
