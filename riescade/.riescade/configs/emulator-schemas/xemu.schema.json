{
  "$schema": "riescade-emulator-schema-v1",
  "id": "xemu",
  "name": "Xemu",
  "description": "Emulador de Xbox Original.",
  "icon": "xemu",
  "configFiles": [{ "path": "xemu.toml", "format": "toml" }],
  "globalMappings": { "fullscreen": { "configKey": "forcefullscreen", "globalKey": "fullscreen" }, "vsync": { "configKey": "xemu_vsync", "globalKey": "vsync" } },
  "groups": [
    { "id": "graphics", "title": "Gráficos", "icon": "monitor", "order": 1, "options": [
      { "id": "xemu_vsync", "label": "V-Sync", "description": "Sincronização vertical.", "type": "toggle", "default": "true", "configKey": "xemu_vsync", "inheritsGlobal": "vsync" },
      { "id": "render_scale", "label": "Escala de Renderização", "description": "Multiplicador da resolução interna do Xbox.", "type": "select", "default": "1", "configKey": "render_scale", "values": [{ "label": "1x Nativa", "value": "1" }, { "label": "2x", "value": "2" }, { "label": "3x", "value": "3" }, { "label": "4x", "value": "4" }, { "label": "5x", "value": "5" }] }
    ]}
  ]
}
