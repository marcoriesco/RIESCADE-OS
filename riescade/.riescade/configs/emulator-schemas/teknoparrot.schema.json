          "id": "tp_stooz",
          "label": "JOYSTICK DEADZONE",
          "description": "This is helpful in driving games to make it less 'twitchy' when using a controller to steer.",
          "type": "slider",
          "default": "auto",
          "configKey": "tp_stooz",
          "min": 0,
          "max": 50,
          "step": 5,
          "suffix": "%"
        },
        {
          "id": "tp_padindex1",
          "label": "FORCE PLAYER 1 PAD INDEX",
          "description": "Force P1 pad index, can be useful if XInput devices or not odered right.",
