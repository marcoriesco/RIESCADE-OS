{
  "$schema": "riescade-emulator-schema-v1",
  "id": "teknoparrot",
  "name": "TEKNOPARROT",
  "description": "Configurações para o emulador TEKNOPARROT geradas a partir do es_features.cfg.",
  "icon": "teknoparrot",
  "configFiles": [],
  "globalMappings": {},
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "tp_fsmode",
          "label": "FULLSCREEN MODE",
          "type": "select",
          "default": "auto",
          "configKey": "tp_fsmode",
          "values": [
            {
              "label": "WINDOWED",
              "value": "0"
            },
            {
              "label": "FULLSCREEN WINDOW",
              "value": "1"
            },
            {
              "label": "EXCLUSIVE FULLSCREEN",
              "value": "2"
            }
          ],
          "realKey": "tp_fsmode",
          "realFile": "TeknoParrot.generator.cs"
        },
        {
          "id": "tp_useScreenres",
          "label": "USE SCREEN RESOLUTION",
          "description": "Force resolution to current screen resolution for games that allow custom resolution.",
          "type": "toggle",
          "default": "auto",
          "configKey": "tp_useScreenres"
        },
        {
          "id": "tp_customres",
          "label": "USE CUSTOM RESOLUTION",
          "description": "Enable custom resolution based Ativado Vídeo mode.",
          "type": "toggle",
          "default": "auto",
          "configKey": "tp_customres"
        },
        {
          "id": "tp_play_resolution",
          "label": "Resolução Interna",
          "type": "select",
          "default": "auto",
          "configKey": "tp_play_resolution",
          "values": [
            {
              "label": "480p",
              "value": "480p"
            },
            {
              "label": "960p",
              "value": "960p"
            },
            {
              "label": "1920p",
              "value": "1920p"
            },
            {
              "label": "4320p",
              "value": "4320p"
            },
            {
              "label": "7680p",
              "value": "7680p"
            }
          ]
        },
        {
          "id": "tp_play_gpuapi",
          "label": "Vídeo",
          "type": "select",
          "default": "auto",
          "configKey": "tp_play_gpuapi",
          "values": [
            {
              "label": "VULKAN",
              "value": "Vulkan"
            },
            {
              "label": "OPENGL",
              "value": "OpenGL"
            }
          ]
        },
        {
          "id": "tp_rpcs3_resolution",
          "label": "Resolução Interna",
          "type": "slider",
          "default": "auto",
          "configKey": "tp_rpcs3_resolution",
          "min": 25,
          "max": 800,
          "step": 25
        },
        {
          "id": "tp_rpcs3_writecolorbuffers",
          "label": "WRITE COLOR BUFFERS",
          "description": "Enable this option if you get missing graphics or broken lighting ingame.",
          "type": "toggle",
          "default": "auto",
          "configKey": "tp_rpcs3_writecolorbuffers"
        },
        {
          "id": "tp_rpcs3_gpuapi",
          "label": "Vídeo",
          "type": "select",
          "default": "auto",
          "configKey": "tp_rpcs3_gpuapi",
          "values": [
            {
              "label": "VULKAN",
              "value": "Vulkan"
            },
            {
              "label": "OPENGL",
              "value": "OpenGL"
            }
          ]
        }
      ]
    },
    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "tp_region",
          "label": "REGION/LANGUAGE",
          "type": "select",
          "default": "auto",
          "configKey": "tp_region",
          "values": [
            {
              "label": "USA/ENGLISH",
              "value": "usa"
            },
            {
              "label": "EXPORT/ENGLISH",
              "value": "export"
            },
            {
              "label": "JAPANESE",
              "value": "japan"
            }
          ]
        },
        {
          "id": "tp_freePlay",
          "label": "FREE PLAY",
          "type": "toggle",
          "default": "auto",
          "configKey": "tp_freePlay"
        },
        {
          "id": "requires_admin",
          "label": "DISABLE ADMIN RIGHTS",
          "type": "toggle",
          "default": "auto",
          "configKey": "requires_admin"
        },
        {
          "id": "apm3id",
          "label": "APM3ID (REQUIRE ONLINE PROFILE)",
          "type": "input",
          "default": "auto",
          "configKey": "apm3id"
        },
        {
          "id": "tp_minimize",
          "label": "HIDE TEKNOPARROT Ativado STARTUP",
          "description": "Hidden by Padrão, for few games can cause problem.",
          "type": "toggle",
          "default": "auto",
          "configKey": "tp_minimize"
        }
      ]
    },
    {
      "id": "hacks",
      "title": "Correções / Hacks",
      "icon": "wrench",
      "order": 3,
      "options": [
        {
          "id": "tp_offscreenhack",
          "label": "OFFSCREEN RELOAD HACK",
          "type": "toggle",
          "default": "auto",
          "configKey": "tp_offscreenhack"
        }
      ]
    },
    {
