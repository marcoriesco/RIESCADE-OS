            },
            {
              "label": "8 BIT (MONOCHROME)",
              "value": "8bit Monochrome"
            },
            {
              "label": "15 BIT COLOR",
              "value": "15bit Color"
            }
          ]
        },
        {
          "id": "gba_colors",
