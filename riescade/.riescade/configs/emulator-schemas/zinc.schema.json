{
  "$schema": "riescade-emulator-schema-v1",
  "id": "zinc",
  "name": "ZiNc (Arcade Sony ZN-1/ZN-2)",
  "description": "Ajuste os parâmetros do emulador ZiNc.",
  "icon": "zinc",
  "configFiles": [],
  "globalMappings": {},
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "zinc_colordepth",
          "label": "COLOR DEPTH",
          "type": "select",
          "default": "auto",
          "configKey": "zinc_colordepth",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "32 bits",
              "value": "32"
            },
            {
              "label": "16 bits",
              "value": "16"
            }
          ],
          "realKey": "ColorDepth",
          "realFile": "Zinc.Generator.cs"
        },
        {
          "id": "zinc_scanlines",
          "label": "SCANLINES",
          "type": "select",
          "default": "auto",
          "configKey": "zinc_scanlines",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "Nenhum",
              "value": "0"
            },
            {
              "label": "BLACK",
              "value": "1"
            },
            {
              "label": "BRIGHT",
              "value": "2"
            }
          ],
          "realKey": "ScanLines",
          "realFile": "Zinc.Generator.cs"
        },
        {
          "id": "zinc_renderer",
          "label": "Vídeo",
          "type": "select",
          "default": "auto",
          "configKey": "zinc_renderer",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "OPENGL",
              "value": "ogl"
            },
            {
              "label": "DIRECT3D",
              "value": "d3d"
            }
          ]
        }
      ]
    },
    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "zinc_frameskip",
          "label": "FRAMESKIP",
          "description": "Skip frames to improve performance (smoothless).",
          "type": "toggle",
          "default": "auto",
          "configKey": "zinc_frameskip",
          "realKey": "FrameSkipping",
          "realFile": "Zinc.Generator.cs"
        },
        {
          "id": "zinc_fps",
          "label": "SHOW FPS",
          "type": "toggle",
          "default": "auto",
          "configKey": "zinc_fps",
          "realKey": "ShowFPS",
          "realFile": "Zinc.Generator.cs"
        }
      ]
    },
    {
      "id": "controls",
      "title": "Controles",
      "icon": "gamepad2",
      "order": 5,
      "options": [
        {
          "id": "zinc_controller_config",
          "label": "CONTROLLER CONFIGURATION METHOD",
          "description": "'PRE-DEFINED' uses the config files located in the emulator 'cfg' folder, 'DYNAMIC' generates configuration based Ativado profile selected in 'Controles' Configurações Avançadas.",
          "type": "select",
          "default": "auto",
          "configKey": "zinc_controller_config",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "DYNAMIC PROFILE",
              "value": "autoconfig"
            },
            {
              "label": "PRE-DEFINED FILES",
              "value": "predefined"
            },
            {
              "label": "Nenhum",
              "value": "none"
            }
          ],
          "realKey": "zinc_controller_config",
          "realFile": "Zinc.Controllers.cs"
        },
        {
          "id": "zinc_control_scheme",
          "label": "CONTROL SCHEME",
          "description": "Select controller layout to use when using 'Dynamic Profile' option.",
          "type": "select",
          "default": "auto",
          "configKey": "zinc_control_scheme",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "STANDARD",
              "value": "standard"
            },
            {
              "label": "STREET FIGHTER",
              "value": "sf"
            },
            {
              "label": "SOUL EDGE",
              "value": "edge"
            },
            {
              "label": "TEKKEN",
              "value": "tekken"
            }
          ],
          "realKey": "zinc_control_scheme",
          "realFile": "Zinc.Controllers.cs"
        },
        {
