        {
          "id": "fbneo_ips",
          "label": "ENABLE IPS PATCH",
          "description": "Enable ips patches.",
          "type": "toggle",
          "default": "auto",
          "configKey": "fbneo_ips"
        },
        {
          "id": "fbneo_patch",
          "label": "ENABLE IPS PATCH",
          "description": "Specify IPS patch to enable, if not set all patches defined in ips .ini will be used.",
          "type": "input",
          "default": "auto",
          "configKey": "fbneo_patch"
