    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "fbneo_hiscore",
          "label": "ENABLE HISCORES",
          "type": "toggle",
          "default": "auto",
          "configKey": "fbneo_hiscore",
          "realKey": "EnableHiscores",
          "realFile": "Fbneo.Generator.cs"
        },
        {
          "id": "fbneo_runahead",
          "label": "ENABLE RUN-AHEAD",
          "description": "Enable run-ahead mode for the reduction of input lag.",
          "type": "toggle",
          "default": "auto",
          "configKey": "fbneo_runahead",
