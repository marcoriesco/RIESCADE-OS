        {
          "id": "cemu_microphone",
          "label": "ENABLE COMPUTER MICROPHONE",
          "description": "Use Padrão computer Áudio input device as microphone.",
          "type": "toggle",
          "default": "auto",
          "configKey": "cemu_microphone"
