{
  "$schema": "riescade-emulator-schema-v1",
  "id": "cemu",
  "name": "CEMU",
  "description": "Configurações para o emulador CEMU",
  "icon": "cemu",
  "configFiles": [],
  "globalMappings": {},
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "stretch",
          "label": "Proporção de Tela",
          "type": "select",
          "default": "auto",
          "configKey": "stretch",
          "values": [
            {
              "label": "KEEP ASPECT RATIO",
              "value": "0"
            },
            {
              "label": "Esticar TO DISPLAY",
              "value": "1"
            }
          ],
          "realKey": "FullscreenScaling",
          "realFile": "Cemu.Generator.cs"
        },
        {
          "id": "cemu_vsync",
          "label": "Sincronização Vertical (V-Sync)",
          "description": "'Triplo-buffer' and 'match emulated content' are only available with Vulkan Vídeo driver.",
          "type": "select",
          "default": "auto",
          "configKey": "cemu_vsync",
          "values": [
            {
              "label": "Duplo-BUFFER",
              "value": "1"
            },
            {
              "label": "Triplo-BUFFER",
              "value": "2"
            },
            {
              "label": "MATCH EMULATED CONTENT",
              "value": "3"
            },
            {
              "label": "Não",
              "value": "0"
            }
          ],
          "realKey": "VSync",
          "realFile": "Cemu.Generator.cs"
        },
        {
          "id": "async_texture",
          "label": "ASYNCHRONOUS TEXTURE COMPILATION",
          "description": "Can improve performance Ativado more powerful GPUs that have spare headroom. Only works with Vulkan renderer.",
          "type": "toggle",
          "default": "auto",
          "configKey": "async_texture",
          "realKey": "AsyncCompile",
          "realFile": "Cemu.Generator.cs"
        },
        {
          "id": "accurate_sync",
          "label": "ACCURATE TEXTURE SYNC",
          "description": "More accurate behavior but may cause lower performance. Ativado by Padrão.",
          "type": "toggle",
          "default": "auto",
          "configKey": "accurate_sync",
          "realKey": "GX2DrawdoneSync",
          "realFile": "Cemu.Generator.cs"
        },
        {
          "id": "upscaleFilter",
          "label": "UPSCALE FILTER",
          "description": "Specify filter to use for upscaling. BICUBIC by Padrão.",
          "type": "select",
          "default": "auto",
          "configKey": "upscaleFilter",
          "values": [
            {
              "label": "BILINEAR",
              "value": "0"
            },
            {
              "label": "BICUBIC",
              "value": "1"
            },
            {
              "label": "HERMITE",
              "value": "2"
            },
            {
              "label": "NEAREST NEIGHBOR",
              "value": "3"
            }
          ],
          "realKey": "UpscaleFilter",
          "realFile": "Cemu.Generator.cs"
        },
        {
          "id": "downscaleFilter",
          "label": "DOWNSCALE FILTER",
          "description": "Specify filter to use for downscaling. BILINEAR by Padrão.",
          "type": "select",
          "default": "auto",
          "configKey": "downscaleFilter",
          "values": [
            {
              "label": "BILINEAR",
              "value": "0"
            },
            {
              "label": "BICUBIC",
              "value": "1"
            },
            {
              "label": "HERMITE",
              "value": "2"
            },
            {
              "label": "NEAREST NEIGHBOR",
              "value": "3"
            }
          ],
          "realKey": "DownscaleFilter",
          "realFile": "Cemu.Generator.cs"
        },
        {
          "id": "video_renderer",
          "label": "Vídeo",
          "type": "select",
          "default": "auto",
          "configKey": "video_renderer",
          "values": [
            {
              "label": "OPENGL",
              "value": "0"
            },
            {
              "label": "VULKAN",
              "value": "1"
            }
          ],
          "realKey": "video_renderer",
          "realFile": "Cemu.Generator.cs"
        }
      ]
