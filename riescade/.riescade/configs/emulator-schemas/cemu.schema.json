{
  "$schema": "riescade-emulator-schema-v1",
  "id": "cemu",
  "name": "Cemu",
  "description": "Emulador de Nintendo Wii U.",
  "icon": "cemu",
  "configFiles": [
    {
      "path": "portable/settings.xml",
      "format": "xml"
    }
  ],
  "globalMappings": {
    "fullscreen": {
      "configKey": "fullscreen",
      "globalKey": "fullscreen"
    },
    "vsync": {
      "configKey": "vsync",
      "globalKey": "vsync"
    },
    "video_driver": {
      "configKey": "video_driver",
      "globalKey": "video_driver"
    }
  },
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "fullscreen",
          "label": "Tela Cheia",
          "description": "Iniciar o emulador em modo tela cheia.",
          "type": "toggle",
          "default": "true",
          "configKey": "fullscreen",
          "inheritsGlobal": "fullscreen"
        },
        {
          "id": "video_driver",
          "label": "Renderizador",
          "description": "API gráfica. 1 = Vulkan, 0 = OpenGL.",
          "type": "select",
          "default": "1",
          "configKey": "video_driver",
          "inheritsGlobal": "video_driver",
          "values": [
            {
              "label": "Vulkan",
              "value": "1"
            },
            {
              "label": "OpenGL",
              "value": "0"
            }
          ]
        },
        {
          "id": "vsync",
          "label": "V-Sync",
          "description": "Sincronização vertical. 0 = Off, 1 = On, 2 = Double, 3 = Triple.",
          "type": "select",
          "default": "1",
          "configKey": "vsync",
          "inheritsGlobal": "vsync",
          "values": [
            {
              "label": "Desativado",
              "value": "0"
            },
            {
              "label": "Ativado",
              "value": "1"
            },
            {
              "label": "Double Buffering",
              "value": "2"
            },
            {
              "label": "Triple Buffering",
              "value": "3"
            }
          ]
        },
        {
          "id": "cemu_upscale_filter",
          "label": "Filtro de Upscaling",
          "description": "Filtro para aumentar a resolução.",
          "type": "select",
          "default": "auto",
          "configKey": "cemu_upscale_filter",
          "values": [
            {
              "label": "Automático",
              "value": "auto"
            },
            {
              "label": "Bilinear",
              "value": "bilinear"
            },
            {
              "label": "Nearest",
              "value": "nearest"
            },
            {
              "label": "Bicubic",
              "value": "bicubic"
            }
          ]
        },
        {
          "id": "cemu_async_compile",
          "label": "Compilação Assíncrona de Shaders",
          "description": "Compila shaders em background. Reduz stuttering.",
          "type": "toggle",
          "default": "true",
          "configKey": "cemu_async_compile"
        }
      ]
    }
  ]
}