{
  "$schema": "riescade-emulator-schema-v1",
  "id": "cemu",
  "name": "Cemu",
  "description": "Emulador de Nintendo Wii U.",
  "icon": "cemu",
  "configFiles": [{ "path": "portable/settings.xml", "format": "xml" }],
  "globalMappings": { "fullscreen": { "configKey": "forcefullscreen", "globalKey": "fullscreen" }, "vsync": { "configKey": "cemu_vsync", "globalKey": "vsync" }, "video_driver": { "configKey": "video_renderer", "globalKey": "video_driver" } },
  "groups": [
    { "id": "graphics", "title": "Gráficos", "icon": "monitor", "order": 1, "options": [
      { "id": "video_renderer", "label": "Renderizador", "description": "API gráfica. 1 = Vulkan, 0 = OpenGL.", "type": "select", "default": "1", "configKey": "video_renderer", "inheritsGlobal": "video_driver", "values": [{ "label": "Vulkan", "value": "1" }, { "label": "OpenGL", "value": "0" }] },
      { "id": "cemu_vsync", "label": "V-Sync", "description": "Sincronização vertical. 0 = Off, 1 = On, 2 = Double, 3 = Triple.", "type": "select", "default": "1", "configKey": "cemu_vsync", "inheritsGlobal": "vsync", "values": [{ "label": "Desativado", "value": "0" }, { "label": "Ativado", "value": "1" }, { "label": "Double Buffering", "value": "2" }, { "label": "Triple Buffering", "value": "3" }] },
      { "id": "cemu_upscale_filter", "label": "Filtro de Upscaling", "description": "Filtro para aumentar a resolução.", "type": "select", "default": "auto", "configKey": "cemu_upscale_filter", "values": [{ "label": "Automático", "value": "auto" }, { "label": "Bilinear", "value": "bilinear" }, { "label": "Nearest", "value": "nearest" }, { "label": "Bicubic", "value": "bicubic" }] },
      { "id": "cemu_async_compile", "label": "Compilação Assíncrona de Shaders", "description": "Compila shaders em background. Reduz stuttering.", "type": "toggle", "default": "true", "configKey": "cemu_async_compile" }
    ]}
  ]
}
