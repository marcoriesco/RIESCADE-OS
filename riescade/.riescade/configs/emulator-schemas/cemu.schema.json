              "label": "Deutsch",
              "value": "3"
            },
            {
              "label": "Italiano",
              "value": "4"
            },
            {
              "label": "Español",
              "value": "5"
            },
            {
              "label": "简体中文 (Chinese)",
              "value": "6"
            },
            {
              "label": "한국어 (Korean)",
              "value": "7"
            },
            {
              "label": "Nederlands",
              "value": "8"
            },
            {
              "label": "Português",
              "value": "9"
            },
            {
              "label": "Русский (Russian)",
              "value": "10"
            }
          ],
          "realKey": "console_language",
          "realFile": "Cemu.Generator.cs"
        },
        {
          "id": "overlay",
          "label": "PERFORMANCE STATISTICS",
          "description": "Show performance statistics overlay in-game.",
          "type": "select",
          "default": "auto",
          "configKey": "overlay",
          "values": [
            {
              "label": "FULL",
              "value": "full"
            },
            {
              "label": "FPS ONLY",
              "value": "fps"
            },
            {
              "label": "Nenhum",
              "value": "none"
            }
          ],
          "realKey": "overlay",
          "realFile": "Cemu.Generator.cs"
        },
        {
          "id": "notifications",
          "label": "NOTIFICATIONS",
          "description": "Turn Ativado emulator notifications : connected controllers and shader compilation messages.",
          "type": "toggle",
          "default": "auto",
          "configKey": "notifications"
        }
      ]
    },
    {
      "id": "audio",
      "title": "Áudio",
      "icon": "volume2",
      "order": 4,
      "options": [
        {
          "id": "channels",
          "label": "Áudio CHANNELS",
          "description": "Configure this setting if you want to switch between stereo and surround sound.",
          "type": "select",
          "default": "auto",
          "configKey": "channels",
          "values": [
            {
              "label": "MONO",
              "value": "0"
