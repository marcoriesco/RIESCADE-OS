{
  "$schema": "riescade-emulator-schema-v1",
  "id": "mame64",
  "name": "MAME 64-bit (Arcade)",
  "description": "Ajuste os parâmetros específicos do emulador MAME 64-bit.",
  "icon": "mame",
  "globalMappings": {
    "fullscreen": {
      "configKey": "fullscreen",
      "globalKey": "fullscreen"
    },
    "vsync": {
      "configKey": "vsync",
      "globalKey": "vsync"
    },
    "aspect_ratio": {
      "configKey": "aspect_ratio",
      "globalKey": "aspect_ratio"
    },
    "video_driver": {
      "configKey": "video_driver",
      "globalKey": "video_driver"
    },
    "audio_driver": {
      "configKey": "audio_driver",
      "globalKey": "audio_driver"
    }
  },
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "video_driver",
          "label": "Backend de Vídeo",
          "description": "API gráfica do MAME.",
          "type": "select",
          "default": "d3d",
          "configKey": "video_driver",
          "inheritsGlobal": "video_driver",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "Direct3D",
              "value": "d3d"
            },
            {
              "label": "OpenGL",
              "value": "opengl"
            },
            {
              "label": "BGFX",
              "value": "bgfx"
            },
            {
              "label": "GDI",
              "value": "gdi"
            }
          ]
        },
        {
          "id": "fullscreen",
          "label": "Tela Cheia",
          "description": "Iniciar o emulador em modo tela cheia.",
          "type": "toggle",
          "default": "true",
          "configKey": "fullscreen",
          "inheritsGlobal": "fullscreen"
        },
        {
          "id": "aspect_ratio",
          "label": "Proporção de Tela",
          "description": "Proporção de aspecto padrão para os emuladores.",
          "type": "select",
          "default": "Fixed4x3",
          "configKey": "aspect_ratio",
          "inheritsGlobal": "aspect_ratio",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "4:3",
              "value": "Fixed4x3"
            },
            {
              "label": "16:9",
              "value": "Fixed16x9"
            },
            {
              "label": "16:10",
              "value": "Fixed16x10"
            },
            {
              "label": "Esticar",
              "value": "Stretch"
            }
          ]
        },
        {
          "id": "vsync",
          "label": "V-Sync",
          "description": "Sincronização vertical.",
          "type": "toggle",
          "default": "true",
          "configKey": "vsync",
          "inheritsGlobal": "vsync"
        }
      ]
    },
    {
      "id": "audio",
      "title": "Áudio",
      "icon": "volume2",
      "order": 2,
      "options": [
        {
          "id": "audio_driver",
          "label": "Backend de Áudio",
          "description": "API de áudio.",
          "type": "select",
          "default": "dsound",
          "configKey": "audio_driver",
          "inheritsGlobal": "audio_driver",
          "values": [
            {
              "label": "DirectSound",
              "value": "dsound"
            },
            {
              "label": "PortAudio",
              "value": "portaudio"
            }
          ]
        }
      ]
    }
  ]
}