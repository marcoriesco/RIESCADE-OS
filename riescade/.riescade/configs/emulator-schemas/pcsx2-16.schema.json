          "default": "auto",
          "configKey": "TextureOffsets",
          "values": [
            {
              "label": "X:0500 Y:0500 (Persona 3, Haunting Ground)",
              "value": "1"
            },
            {
              "label": "X:0000 Y:1000 (Xenosaga)",
              "value": "2"
            }
          ],
          "realKey": "TextureOffsets",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "UserHacks_Disable_Safe_Features",
          "label": "SAFE FEATURES (HACK)",
          "description": "Disabling safe features can help various games such as Xenosaga, Kingdom Hearts...",
          "type": "toggle",
          "default": "auto",
          "configKey": "UserHacks_Disable_Safe_Features",
          "realKey": "UserHacks_Disable_Safe_Features",
          "realSection": "Settings",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "UserHacks_SkipDraw_Start",
          "label": "SKIPDRAW START (HACK)",
          "description": "A shadows and colors fix needed for some games such as Tony Hawk Proving Ground.",
          "type": "slider",
          "default": "auto",
          "configKey": "UserHacks_SkipDraw_Start",
          "min": 0,
          "max": 20,
          "step": 1,
          "realKey": "UserHacks_SkipDraw_Offset",
          "realSection": "Settings",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "UserHacks_SkipDraw_End",
          "label": "SKIPDRAW END (HACK)",
          "type": "slider",
          "default": "auto",
          "configKey": "UserHacks_SkipDraw_End",
          "min": 0,
          "max": 20,
          "step": 1,
          "realKey": "UserHacks_SkipDraw",
          "realSection": "Settings",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "crc_hack_level",
          "label": "CRC LEVEL (HACK)",
          "description": "Controles the number of Automático-CRC fixes and Hacks / Velocidade applied to games.",
          "type": "select",
          "default": "auto",
          "configKey": "crc_hack_level",
          "values": [
            {
              "label": "AGRESSIVE",
              "value": "4"
