          "realKey": "crc_hack_level",
          "realSection": "Settings",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "negdivhack",
          "label": "SPEED Hacks / Velocidade",
          "description": "Significantly improves performances for CPU with 3+ cores.",
          "type": "toggle",
          "default": "auto",
          "configKey": "negdivhack"
        }
      ]
    }
