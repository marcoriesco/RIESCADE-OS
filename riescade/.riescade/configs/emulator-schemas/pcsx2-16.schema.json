          "default": "auto",
          "configKey": "UserHacks",
          "realKey": "UserHacks",
          "realSection": "EmuCore/GS",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "Offset",
          "label": "LOWER GS PRECISION (HACK)",
          "description": "Avoid gap between pixels when upscaling. Fix Wild Arms text, SoulCalibur ghosting.",
