            {
              "label": "USA 230",
              "value": "ps2-0230a-20080220.bin"
            },
            {
              "label": "EUR 230",
              "value": "ps2-0230e-20080220.bin"
            },
            {
              "label": "EUR 250",
              "value": "ps2-0250e-20100415.bin"
            },
            {
              "label": "JAP 230",
              "value": "ps2-0230j-20080220.bin"
            },
            {
              "label": "PS3 PS2 FIRMWARE",
              "value": "ps3_ps2_emu_bios.bin"
            }
          ]
        },
        {
          "id": "gs_plugin",
          "label": "GRAPHICS PLUGINS",
