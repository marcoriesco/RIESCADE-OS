          "default": "auto",
          "configKey": "Offset"
        },
        {
          "id": "UserHacks_Half_Bottom_Override",
          "label": "HALF-SCREEN (HACK)",
          "description": "'Automático' will Controles the half-screen fix detection Ativado texture shuffling.",
          "type": "select",
          "default": "auto",
          "configKey": "UserHacks_Half_Bottom_Override",
          "values": [
            {
              "label": "FORCE DISABLE (For Xenosaga games)",
              "value": "0"
            },
            {
              "label": "FORCE ENABLE (If issues Ativado Automático)",
              "value": "1"
            }
          ],
          "realKey": "UserHacks_Half_Bottom_Override",
          "realSection": "Settings",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "UserHacks_HalfPixelOffset",
          "label": "HALF PIXEL OFFSET (HACK)",
          "description": "Might fix some misaligned fog, bloom or blend effect.",
          "type": "select",
          "default": "auto",
          "configKey": "UserHacks_HalfPixelOffset",
          "values": [
            {
              "label": "Não",
              "value": "0"
            },
            {
              "label": "NORMAL (VERTEX)",
              "value": "1"
            },
            {
              "label": "SPECIAL (TEXTURE)",
              "value": "2"
            },
            {
              "label": "SPECIAL (TEXTURE AGRESSIVE)",
              "value": "3"
            }
          ],
          "realKey": "UserHacks_HalfPixelOffset",
          "realSection": "Settings",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "UserHacks_round_sprite_offset",
          "label": "ROUND SPRITE (HACK)",
          "description": "Correct the sampling of 2D sprite textures when upscaling.",
          "type": "select",
          "default": "auto",
          "configKey": "UserHacks_round_sprite_offset",
          "values": [
            {
              "label": "Não",
              "value": "0"
            },
            {
              "label": "HALF",
              "value": "1"
            },
            {
              "label": "FULL",
              "value": "2"
            }
          ],
          "realKey": "UserHacks_round_sprite_offset",
          "realSection": "Settings",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "align_sprite",
          "label": "ALIGN SPRITE (HACK)",
          "description": "Fix issues with upscaling in Namco games (Ace Combat, Tekken, SoulCalibur...).",
          "type": "toggle",
          "default": "auto",
          "configKey": "align_sprite"
        },
        {
          "id": "UserHacks_merge_pp_sprite",
          "label": "MERGE SPRITE (HACK)",
          "description": "Replaces post-processing multiple paving sprites by a single fat sprite.",
          "type": "toggle",
          "default": "auto",
          "configKey": "UserHacks_merge_pp_sprite",
          "realKey": "UserHacks_merge_pp_sprite",
          "realSection": "Settings",
          "realFile": "Pcsx2.Generator.cs"
        },
        {
          "id": "TextureOffsets",
          "label": "TEXTURE OFFSETS (HACK)",
          "description": "Offset for the ST/UV texture coordinates.",
