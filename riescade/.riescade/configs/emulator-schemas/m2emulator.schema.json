{
  "$schema": "riescade-emulator-schema-v1",
  "id": "m2emulator",
  "name": "Model 2 Emulator (Sega Model 2)",
  "description": "Ajuste os parâmetros do Sega Model 2 Emulator.",
  "icon": "m2emulator",
  "configFiles": [],
  "globalMappings": {},
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "VSync",
          "label": "VSYNC",
          "type": "toggle",
          "default": "auto",
          "configKey": "VSync",
          "realKey": "ForceSync",
          "realSection": "Renderer",
          "realFile": "Model2.Generator.cs"
        },
        {
          "id": "m2_widescreen",
          "label": "ASPECT RATIO",
          "type": "select",
          "default": "auto",
          "configKey": "m2_widescreen",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "4:3",
              "value": "0"
            },
            {
              "label": "16:9",
              "value": "1"
            }
          ]
        },
        {
          "id": "bilinear_filtering",
          "label": "Filtragem Bilinear",
          "description": "Use Filtragem Bilinear to smooth the overall picture.",
          "type": "toggle",
          "default": "auto",
          "configKey": "bilinear_filtering",
          "realKey": "Bilinear",
          "realSection": "Renderer",
          "realFile": "Model2.Generator.cs"
        },
        {
          "id": "trilinear_filtering",
          "label": "Filtragem Trilinear",
          "description": "Control the texture tri-filtering of the Emulação.",
          "type": "toggle",
          "default": "auto",
          "configKey": "trilinear_filtering",
          "realKey": "Trilinear",
          "realSection": "Renderer",
          "realFile": "Model2.Generator.cs"
        },
        {
          "id": "m2_ForceManaged",
          "label": "FORCE MANAGED TEXTURES",
          "description": "Use this if the emulator crashes after loading or doesn't show anything.",
          "type": "toggle",
          "default": "auto",
          "configKey": "m2_ForceManaged",
          "realKey": "ForceManaged",
          "realSection": "Renderer",
          "realFile": "Model2.Generator.cs"
        },
        {
          "id": "m2_fsaa",
          "label": "Anti-Aliasing (FXAA)",
          "description": "Enable full screen antialiasing in Direct3D, smooth polygons edges.",
          "type": "toggle",
          "default": "auto",
          "configKey": "m2_fsaa",
          "realKey": "FSAA",
          "realSection": "Renderer",
          "realFile": "Model2.Generator.cs"
        }
      ]
    },
    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "m2_AutoMip",
          "label": "Automático MIPMAP",
          "description": "Enables Direct3D Automipmap generation.",
          "type": "toggle",
          "default": "auto",
          "configKey": "m2_AutoMip",
          "realKey": "AutoMip",
          "realSection": "Renderer",
          "realFile": "Model2.Generator.cs"
        },
        {
          "id": "m2_enable_service",
          "label": "SERVICE MODE",
          "description": "Enable R3 as Service button to enter settings.",
          "type": "toggle",
          "default": "auto",
          "configKey": "m2_enable_service"
        }
      ]
    },
    {
      "id": "controls",
      "title": "Controles",
      "icon": "gamepad2",
      "order": 5,
      "options": [
        {
          "id": "m2_joystick_driver",
          "label": "CONTROLLER",
          "type": "select",
          "default": "auto",
          "configKey": "m2_joystick_driver",
          "values": [
            {
              "label": "AUTO",
              "value": "auto"
            },
            {
              "label": "XINPUT",
              "value": "xinput"
            },
            {
              "label": "DINPUT",
              "value": "dinput"
            }
          ],
          "realKey": "m2_joystick_driver",
          "realFile": "Model2.Generator.cs"
        },
        {
          "id": "m2_racingshoulder",
          "label": "USE SHOULDER BUTTONS FOR RACING GAMES",
          "description": "Use R1 and L1 to accelerate and brake in racing games, only compatible with 'Automático' gear shifting.",
          "type": "toggle",
          "default": "auto",
          "configKey": "m2_racingshoulder"
        },
        {
          "id": "m2_joystick_autoconfig",
          "label": "TYPE OF AUTOCONFIGURATION",
          "description": "'Templates' option copies files located in 'emulators\\m2emulator\\templatescfg' folder instead of performing dynamic autoconfiguration.",
          "type": "select",
          "default": "auto",
          "configKey": "m2_joystick_autoconfig",
