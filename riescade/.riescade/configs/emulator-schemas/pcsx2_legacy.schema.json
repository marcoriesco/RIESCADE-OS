{
  "$schema": "riescade-emulator-schema-v1",
  "id": "pcsx2",
  "name": "PCSX2 (Legado)",
  "description": "Emulador de PlayStation 2 — versão legada.",
  "icon": "pcsx2",
  "configFiles": [{ "path": "inis/PCSX2.ini", "format": "ini" }],
  "globalMappings": {
    "fullscreen": { "configKey": "forcefullscreen", "globalKey": "fullscreen" },
    "vsync": { "configKey": "pcsx2_vsync", "globalKey": "vsync" },
    "video_driver": { "configKey": "renderer", "globalKey": "video_driver" }
  },
  "groups": [
    {
      "id": "graphics",
      "title": "Gráficos",
      "icon": "monitor",
      "order": 1,
      "options": [
        {
          "id": "internalresolution",
          "label": "Resolução Interna",
          "description": "Multiplicador da resolução nativa do PS2 (512x448).",
          "type": "select",
          "default": "3",
          "configKey": "internalresolution",
          "values": [
            { "label": "Nativa (1x)", "value": "1" },
            { "label": "2x (1024x896)", "value": "2" },
            { "label": "3x (1536x1344)", "value": "3" },
            { "label": "4x (2048x1792)", "value": "4" },
            { "label": "5x (2560x2240)", "value": "5" },
            { "label": "6x (3072x2688)", "value": "6" },
            { "label": "8x (4096x3584)", "value": "8" }
          ]
        },
        {
          "id": "pcsx2_vsync",
          "label": "V-Sync",
          "description": "Sincronização vertical do PCSX2.",
          "type": "toggle",
          "default": "true",
          "configKey": "pcsx2_vsync",
          "inheritsGlobal": "vsync"
        }
      ]
    },
    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "pcsx2_fastboot",
          "label": "Fast Boot",
          "description": "Pula a animação de boot do PS2 ao iniciar jogos.",
          "type": "toggle",
          "default": "true",
          "configKey": "pcsx2_fastboot"
        }
      ]
    }
  ]
}
