{
  "$schema": "riescade-emulator-schema-v1",
  "id": "ghostship",
  "name": "Ghostship Engine",
  "description": "Ajuste os parâmetros da engine Ghostship.",
  "icon": "ghostship",
  "configFiles": [],
  "globalMappings": {},
  "groups": [
    {
      "id": "emulation",
      "title": "Emulação",
      "icon": "cpu",
      "order": 2,
      "options": [
        {
          "id": "ghostship_resolution",
          "label": "Resolução Interna",
          "type": "select",
          "default": "auto",
          "configKey": "ghostship_resolution",
          "values": [
            {
              "label": "240p (NATIVE)",
              "value": "240"
            },
            {
              "label": "480p",
              "value": "480"
            },
            {
              "label": "720p",
              "value": "720"
            },
            {
              "label": "960p",
              "value": "960"
            },
            {
              "label": "1080p (FULL HD)",
              "value": "1080"
            },
            {
              "label": "1200p",
              "value": "1200"
            },
            {
              "label": "1440p",
              "value": "1440"
            },
            {
              "label": "2160p (4K)",
              "value": "2160"
            }
          ]
        },
        {
          "id": "ghostship_ratio",
          "label": "Proporção de Tela",
          "type": "select",
          "default": "auto",
          "configKey": "ghostship_ratio",
          "values": [
            {
              "label": "NATIVE (4:3)",
              "value": "native"
            },
            {
              "label": "WIDESCREEN (16:9)",
              "value": "widescreen"
            },
            {
              "label": "3DS (5:3)",
              "value": "3ds"
            },
            {
              "label": "16:10",
              "value": "16:10"
            },
            {
              "label": "ULTRAWIDE (21:9)",
              "value": "ultrawide"
            }
          ]
        },
        {
          "id": "ghostship_vsync",
          "label": "Sincronização Vertical (V-Sync)",
          "type": "toggle",
          "default": "auto",
          "configKey": "ghostship_vsync"
        },
        {
          "id": "ghostship_texturefilter",
          "label": "Filtragem de Texturas",
          "type": "select",
          "default": "auto",
          "configKey": "ghostship_texturefilter",
          "values": [
            {
              "label": "LINEAR",
              "value": "1"
            },
            {
              "label": "THREE POINT",
              "value": "0"
            },
            {
              "label": "Nenhum",
              "value": "2"
            }
          ]
        },
        {
          "id": "ghostship_msaa",
          "label": "ANTI ALIASING (MSAA)",
          "description": "Multi-Sampling Anti Aliasing level.",
          "type": "slider",
          "default": "auto",
          "configKey": "ghostship_msaa",
          "min": 1,
          "max": 8,
          "step": 1,
          "suffix": "x"
        },
        {
          "id": "ghostship_fps",
          "label": "TARGET FPS",
          "type": "slider",
          "default": "auto",
          "configKey": "ghostship_fps",
          "min": 30,
          "max": 60,
          "step": 1
        },
        {
          "id": "ghostship_renderer",
          "label": "Vídeo",
          "type": "select",
          "default": "auto",
          "configKey": "ghostship_renderer",
          "values": [
            {
              "label": "OPENGL",
              "value": "OpenGL"
            },
            {
              "label": "DIRECTX",
              "value": "DirectX"
            }
          ]
        }
      ]
    },
    {
      "id": "audio",
      "title": "Áudio",
      "icon": "volume2",
      "order": 4,
      "options": [
        {
          "id": "ghostship_audioapi",
          "label": "Áudio",
          "type": "select",
          "default": "auto",
          "configKey": "ghostship_audioapi",
          "values": [
            {
              "label": "WASAPI",
              "value": "wasapi"
            },
            {
              "label": "SDL",
              "value": "sdl"
            }
          ]
        }
      ]
    },
    {
      "id": "controls",
      "title": "Controles",
      "icon": "gamepad2",
      "order": 5,
      "options": [
        {
          "id": "ship_controllayout",
          "label": "CONTROL LAYOUT",
          "type": "select",
          "default": "auto",
          "configKey": "ship_controllayout",
          "values": [
            {
              "label": "STANDARD (Z LEFTTRIGGER)",
              "value": "z_left"
            },
            {
              "label": "STANDARD (Z RIGHTTRIGGER)",
              "value": "z_right"
            }
          ]
        },
        {
          "id": "n64_pad",
          "label": "USE N64-LIKE CONTROLLER",
          "type": "toggle",
          "default": "auto",
          "configKey": "n64_pad"
        },
        {
          "id": "ship_deadzone",
          "label": "ANALOG DEADZONE",
          "description": "Ignore analog stick movement below this threshold.",
          "type": "slider",
          "default": "auto",
          "configKey": "ship_deadzone",
          "min": 0,
          "max": 50,
          "step": 2,
          "suffix": "%"
        },
        {
          "id": "ship_rumble",
          "label": "ENABLE RUMBLE",
          "description": "Enables joypad rumble.",
          "type": "toggle",
          "default": "auto",
          "configKey": "ship_rumble"
        },
        {
          "id": "ship_rumblestrength",
          "label": "RUMBLE STRENGTH",
          "type": "slider",
          "default": "auto",
          "configKey": "ship_rumblestrength",
          "min": 0,
          "max": 100,
          "step": 5,
          "suffix": "%"
        },
        {
          "id": "ship_gyro",
          "label": "ENABLE MOTION",
          "description": "Can only be used if the controller is compatible with motion control.",
          "type": "toggle",
          "default": "auto",
          "configKey": "ship_gyro"
        },
        {
          "id": "ship_gyroSensivity",
          "label": "GYRO SENSITIVITY",
          "type": "slider",
          "default": "auto",
          "configKey": "ship_gyroSensivity",
          "min": 0,
          "max": 1,
          "step": 0.05,
          "suffix": "%"
        }
      ]
    }
  ]
}